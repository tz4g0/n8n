    {
      "parameters": {
        "jsCode": "const rows = items.map(i => i.json);\nif (!rows.length) throw new Error('Registry is empty \u2014 no table to delete');\nconst sorted = [...rows].sort((a,b) => new Date(b.createdAt) - new Date(a.createdAt));\nconst latestId = sorted[0].dag_table_id;\nconst sheetData = $('Aggregate Sheet Rows').first().json.data || [];\nreturn [{ json: { dag_table_id: latestId, sheet_data: sheetData } }];"
      },
      "id": "node-pick-latest-sync",
      "name": "Pick Latest Table ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1392,
        -64
      ]
    }
