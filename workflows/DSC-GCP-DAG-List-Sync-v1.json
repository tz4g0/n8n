    },
    {
      "parameters": {
        "content": "### Phase 4 \u2014 Insert & Register\nBatch-inserts all sheet rows into the freshly created table using the new table ID from Phase 3. Then appends the new table ID + timestamp to the registry table for audit/lineage.",
        "height": 110,
        "width": 560,
        "color": 5
      },
      "id": "sticky-phase4",
      "name": "Phase 4 Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        2192,
        -208
      ]
    },
