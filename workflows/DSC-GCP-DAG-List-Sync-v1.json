          "name": "tzago-n8n-api-key"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://n8n.ai.telus.com/api/v1/data-tables",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={\"name\":\"SRE_Supported_Composer_Dags\",\"columns\":[{\"name\":\"DAG\",\"type\":\"string\"},{\"name\":\"Datahub_Composer\",\"type\":\"string\"},{\"name\":\"OtherNotes\",\"type\":\"string\"},{\"name\":\"SME\",\"type\":\"string\"},{\"name\":\"Priority\",\"type\":\"string\"},{\"name\":\"Runbook\",\"type\":\"string\"}]}",
        "options": {
          "timeout": 15000
        }
      },
