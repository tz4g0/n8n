      "id": "node-gdrive-fetch",
      "name": "Fetch DAG CSV from Google Sheets",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        288,
        704
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse the CSV text fetched from Google Drive\nconst raw = $input.first().json;\nconst csvText = (raw.data ?? raw.body ?? Object.values(raw)[0] ?? '').toString();\n\nconst COMPOSER_MAP = {\n  'b1':'datahub-composer-c-1-pr','b2':'datahub-composer-c-2-pr',\n  'b3':'datahub-composer-c-3-pr','c1':'datahub-composer-c-1-pr',\n  'c2':'datahub-composer-c-2-pr','c3':'datahub-composer-c-3-pr',\n  'c4':'datahub-composer-c-4-pr','datahub-composer-2':'datahub-composer-c-2-pr'\n};\n\n// Parse CSV into rows (handles quoted fields with newlines)\nconst lines = csvText.split('\\n');\nconst headers = lines[0].split(',').map(h => h.trim().replace(/^\"|\"$/g, ''));\n\nconst rows = [];\nfor (let i = 1; i < lines.length; i++) {\n  const line = lines[i].trim();\n  if (!line) continue;\n  const cols = line.split(',');\n  const row = {};\n  headers.forEach((h, idx) => {\n    row[h] = (cols[idx] ?? '').replace(/^\"|\"$/g, '').trim();\n  });\n  rows.push(row);\n}\n\n// \u2500\u2500 Test: change this dag_id to test different DAGs \u2500\u2500\nconst TEST_DAG_ID = 'GCS_to_BQ_fcty_ccaas_genesys_mediation_segment_fact_load_app';\n// \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\nconst match = rows.find(r => (r['DAG'] ?? '').toLowerCase() === TEST_DAG_ID.toLowerCase());\n\nlet result = {\n  test_dag_id: TEST_DAG_ID,\n  total_rows_loaded: rows.length,\n  match_found: !!match,\n  dag_supported: false,\n  support_status: 'Not Found',\n  composer: '',\n  support_reason: \"DAG '\" + TEST_DAG_ID + \"' not found in CSV\"\n};\n\nif (match) {\n  const composerRaw = (match['Datahub Composer'] ?? '').trim();\n  const notes = (match['OtherNotes'] ?? '').split(';')[0].trim();\n  result.composer = COMPOSER_MAP[composerRaw] ?? composerRaw;\n  result.support_status = notes;\n  result.dag_supported = notes.toLowerCase() !== 'not supported';\n  result.support_reason = \"DAG '\" + TEST_DAG_ID + \"' is \" + notes;\n  result.raw_row = match;\n}\n\nreturn [{ json: result }];\n"
      },
