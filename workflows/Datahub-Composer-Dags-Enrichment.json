    {
      "parameters": {
        "content": "### Check if DAG Supported\n**Get DAG from Table**: Queries n8n Data Table \"SRE_Supported_Composer_Dags\" by dag_id.\n**DAG Support Lookup**: Resolves composer shorthand, sets dag_supported flag.\n**IF**: true (Supported/Critical) \u2192 left, false (Not Found/Not Supported) \u2192 right.",
        "height": 112,
        "width": 700,
        "color": 3
      },
      "id": "sticky-check",
      "name": "Section - Check Support",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        832,
        176
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 1
          },
          "conditions": [
            {
              "id": "check-supported",
              "leftValue": "={{ String($json.dag_supported) }}",
              "rightValue": "true",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-check-dag",
      "name": "Check if DAG supported",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1440,
        304
